{%- comment -%}
  SBG Search Results Page Template
  Renders matched products or pages inside a clean grid layout.
{%- endcomment -%}

<style type="text/css">
  .search-card-img {
    transition: transform 0.9s cubic-bezier(0.215, 0.61, 0.355, 1);
  }
  .search-card:hover .search-card-img {
    transform: scale(1.03);
  }
</style>

<section class="bg-sbg-white w-full py-16 md:py-24 border-b border-sbg-border/60 select-none">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
    
    <!-- Title -->
    <div class="max-w-2xl mx-auto mb-12 reveal-on-scroll" data-stagger-children="0.1">
      <span class="text-[10px] font-bold tracking-[0.3em] uppercase text-sbg-grey block mb-2 stagger-item">
        {{ 'sections.search.catalogue_search' | t }}
      </span>
      
      {%- if search.performed -%}
        <h1 class="font-display text-3xl md:text-4xl font-bold tracking-[0.2em] text-sbg-black uppercase stagger-item">
          {{ 'sections.search.results_for' | t: terms: search.terms }}
        </h1>
      {%- else -%}
        <h1 class="font-display text-3xl md:text-4xl font-bold tracking-[0.2em] text-sbg-black uppercase stagger-item">
          {{ 'sections.search.search_atelier' | t }}
        </h1>
      {%- endif -%}
      
      <div class="h-[1px] w-16 bg-sbg-black mx-auto mt-4 stagger-item"></div>
    </div>

    <!-- Search Form Input -->
    <div class="max-w-md mx-auto mb-16 stagger-item">
      <form action="{{ routes.search_url }}" method="get" role="search" class="relative">
        <input
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'sections.search.search_placeholder' | t }}"
          class="w-full px-5 py-4 pr-12 border border-sbg-border text-xs tracking-wider transition-colors focus:outline-none focus:border-sbg-black bg-sbg-white text-sbg-black placeholder-sbg-grey/55 uppercase text-center"
        >
        <button type="submit" class="absolute right-4 top-1/2 -translate-y-1/2 text-sbg-black hover:text-sbg-gold transition-colors focus:outline-none" aria-label="{{ 'general.accessibility.submit_search' | t }}">
          <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </button>
      </form>
    </div>

    {%- if search.performed -%}
      {%- paginate search.results by 12 -%}
        
        <div class="text-[10px] tracking-widest text-sbg-grey uppercase mb-8 stagger-item">
          {{ 'sections.search.matched_items' | t: count: search.results_count }}
        </div>

        {%- if search.results.size > 0 -%}
          <!-- Grid -->
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 reveal-on-scroll" data-stagger-children="0.08">
            {%- for item in search.results -%}
              {%- if item.object_type == 'product' -%}
                {%- liquid
                  assign current_variant = item.selected_or_first_available_variant
                -%}
                <a href="{{ item.url }}" class="search-card group block relative border border-sbg-border/50 hover:border-sbg-gold/30 hover:shadow-xl hover:shadow-sbg-gold/5 transition-all duration-500 stagger-item">
                  <div class="relative overflow-hidden bg-sbg-offwhite aspect-[3/4]">
                    <!-- Image -->
                    {%- if item.featured_image != blank -%}
                      <img src="{{ item.featured_image | image_url: width: 800 }}" alt="{{ item.title }}" class="search-card-img object-cover w-full h-full">
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'object-cover w-full h-full bg-sbg-hover' }}
                    {%- endif -%}
                  </div>
                  
                  <!-- Info -->
                  <div class="p-4 bg-sbg-white border-t border-sbg-border/40 text-left space-y-1">
                    <h3 class="text-[9px] tracking-[0.18em] uppercase text-sbg-grey/90 truncate font-semibold">
                      {{ item.vendor | default: "Styled by Gloria" }}
                    </h3>
                    <p class="font-display text-sm font-bold tracking-wide uppercase text-sbg-black truncate group-hover:text-sbg-gold transition-colors duration-300">
                      {{ item.title }}
                    </p>
                    <p class="text-xs font-semibold tracking-wider text-sbg-black/80">
                      {{ item.price | money }}
                    </p>
                  </div>
                </a>
              {%- else -%}
                <!-- Page or Article search result card -->
                <a href="{{ item.url }}" class="search-card group block relative border border-sbg-border/50 p-6 bg-sbg-offwhite text-left flex flex-col justify-between hover:border-sbg-gold/30 hover:shadow-xl hover:shadow-sbg-gold/5 transition-all duration-500 aspect-[3/4] stagger-item">
                  <div class="space-y-4">
                    <span class="text-[8px] font-bold tracking-[0.25em] text-sbg-gold uppercase block">
                      {{ item.object_type | uppercase }}
                    </span>
                    <h3 class="font-display text-lg font-bold tracking-wide uppercase text-sbg-black line-clamp-3 group-hover:text-sbg-gold transition-colors duration-300">
                      {{ item.title }}
                    </h3>
                    <p class="text-[11px] tracking-wider leading-relaxed text-sbg-grey/90 line-clamp-4">
                      {{ item.content | strip_html | truncate: 150 }}
                    </p>
                  </div>
                  <div class="inline-flex items-center space-x-1.5 text-[9px] font-bold tracking-[0.25em] text-sbg-black uppercase mt-4">
                    <span>{{ 'sections.search.view_page' | t }}</span>
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>

          <!-- Pagination -->
          {%- if paginate.pages > 1 -%}
            <div class="flex items-center justify-center space-x-6 pt-12 border-t border-sbg-border/40 mt-12 text-[10px] tracking-widest text-sbg-grey uppercase font-semibold">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="hover:text-sbg-black flex items-center space-x-1">
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                  <span>{{ 'general.pagination.previous' | t }}</span>
                </a>
              {%- endif -%}

              <span>PAGE {{ paginate.current_page }} OF {{ paginate.pages }}</span>

              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="hover:text-sbg-black flex items-center space-x-1">
                  <span>{{ 'general.pagination.next' | t }}</span>
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </a>
              {%- endif -%}
            </div>
          {%- endif -%}

        {%- else -%}
          <p class="text-xs tracking-wider text-sbg-grey py-8">
            {{ 'sections.search.no_results' | t }}
          </p>
        {%- endif -%}

      {%- endpaginate -%}
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "SBG Search Results",
  "settings": []
}
{% endschema %}
