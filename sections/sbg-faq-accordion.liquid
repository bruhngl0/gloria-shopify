{%- comment -%}
  SBG Standalone FAQ Accordion Section
{%- endcomment -%}

<style type="text/css">
  .sbg-faq-acc-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.215, 0.61, 0.355, 1), opacity 0.4s ease;
    opacity: 0;
  }
  .sbg-faq-acc-answer.open {
    max-height: 500px;
    opacity: 1;
  }
</style>

<div class="bg-sbg-white w-full py-20 border-b border-sbg-border/60 select-none">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="text-center mb-16 reveal-on-scroll" data-stagger-children="0.1">
      <span class="text-[10px] font-bold tracking-[0.3em] uppercase text-sbg-gold block mb-3 stagger-item">
        {{ section.settings.sub_label | default: "Atelier Help" }}
      </span>
      <h2 class="font-display text-2xl md:text-3xl font-bold tracking-wide text-sbg-black uppercase stagger-item">
        {{ section.settings.title | default: "Frequently Asked Questions" }}
      </h2>
      <div class="h-[1.5px] w-12 bg-sbg-gold mx-auto mt-4 stagger-item"></div>
    </div>

    <!-- FAQ Accordions -->
    <div class="divide-y divide-sbg-border/60 border-t border-b border-sbg-border/60 text-left reveal-on-scroll" data-stagger-children="0.08">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="py-5 stagger-item" {{ block.shopify_attributes }}>
            <button
              type="button"
              onclick="toggleSectionFaq({{ forloop.index }}, '{{ section.id }}')"
              class="flex w-full items-center justify-between text-left group focus:outline-none"
            >
              <span class="font-display text-base md:text-lg font-bold tracking-wide text-sbg-black group-hover:text-sbg-gold transition-colors duration-300">
                {{ block.settings.question }}
              </span>
              <span id="faq-sign-{{ section.id }}-{{ forloop.index }}" class="ml-4 font-light text-2xl text-sbg-grey group-hover:text-sbg-gold transition-colors">
                +
              </span>
            </button>
            <div id="faq-ans-{{ section.id }}-{{ forloop.index }}" class="sbg-faq-acc-answer">
              <div class="text-xs leading-relaxed text-sbg-grey tracking-wider pt-4 max-w-3xl pr-4">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- Fallback FAQs -->
        {%- for i in (1..3) -%}
          <div class="py-5 stagger-item">
            <button
              type="button"
              onclick="toggleSectionFaq({{ i }}, '{{ section.id }}')"
              class="flex w-full items-center justify-between text-left group focus:outline-none"
            >
              <span class="font-display text-base md:text-lg font-bold tracking-wide text-sbg-black group-hover:text-sbg-gold transition-colors duration-300">
                Sample Question {{ i }}
              </span>
              <span id="faq-sign-{{ section.id }}-{{ i }}" class="ml-4 font-light text-2xl text-sbg-grey group-hover:text-sbg-gold transition-colors">
                +
              </span>
            </button>
            <div id="faq-ans-{{ section.id }}-{{ i }}" class="sbg-faq-acc-answer">
              <p class="text-xs leading-relaxed text-sbg-grey tracking-wider pt-4 max-w-3xl pr-4">
                This is a sample answer. Please customize this question and answer content in the theme editor panel.
              </p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</div>

<script>
  function toggleSectionFaq(idx, sectionId) {
    const ans = document.getElementById('faq-ans-' + sectionId + '-' + idx);
    const sign = document.getElementById('faq-sign-' + sectionId + '-' + idx);

    if (ans && sign) {
      if (ans.classList.contains('open')) {
        ans.classList.remove('open');
        sign.textContent = '+';
      } else {
        // Close other FAQs in same section
        document.querySelectorAll('#faq-ans-' + sectionId + '-*').forEach(function(el) {
          el.classList.remove('open');
        });
        document.querySelectorAll('[id^="faq-sign-' + sectionId + '-"]').forEach(function(el) {
          el.textContent = '+';
        });

        ans.classList.add('open');
        sign.textContent = '−';
      }
    }
  }
</script>

{% schema %}
{
  "name": "SBG FAQ Accordion",
  "settings": [
    {
      "type": "text",
      "id": "sub_label",
      "label": "Sub-label",
      "default": "Atelier Help"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Main Title",
      "default": "Frequently Asked Questions"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Accordion Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Your Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Your Answer...</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SBG FAQ Accordion"
    }
  ]
}
{% endschema %}
