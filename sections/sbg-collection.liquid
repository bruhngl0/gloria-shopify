{%- comment -%}
  SBG Premium Collection Grid Template
  Renders active collection pages with sorting, description, and high-fidelity layout.
{%- endcomment -%}

<style type="text/css">
  .col-card-img {
    transition: transform 0.9s cubic-bezier(0.215, 0.61, 0.355, 1);
  }
  .col-card:hover .col-card-img {
    transform: scale(1.04);
  }
</style>

<section class="bg-sbg-white w-full py-16 md:py-24 border-b border-sbg-border/60 select-none">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Collection Title & Description Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 reveal-on-scroll" data-stagger-children="0.1">
      <span class="text-[10px] font-bold tracking-[0.3em] uppercase text-sbg-grey block mb-2 stagger-item">
        Atelier Range
      </span>
      <h1 class="font-display text-4xl md:text-5xl font-bold tracking-[0.2em] text-sbg-black uppercase stagger-item">
        {{ collection.title }}
      </h1>
      <div class="h-[1px] w-16 bg-sbg-black mx-auto mt-4 mb-6 stagger-item"></div>
      
      {%- if collection.description != blank -%}
        <div class="text-xs tracking-wider leading-relaxed text-sbg-grey max-w-xl mx-auto stagger-item">
          {{ collection.description }}
        </div>
      {%- endif -%}
    </div>

    {%- liquid
      assign products_per_page = section.settings.products_per_page | default: 12
    -%}

    {%- paginate collection.products by products_per_page -%}
      
      <!-- Sorting / Count Header -->
      <div class="flex flex-col sm:flex-row items-center justify-between border-b border-sbg-border/60 pb-4 mb-8 text-[10px] tracking-widest text-sbg-grey uppercase stagger-item">
        <div class="mb-2 sm:mb-0">
          Showing {{ collection.products.size }} pieces
        </div>
        <div class="flex items-center space-y-0 space-x-2">
          <label for="SortBy" class="font-semibold text-sbg-black">Sort By:</label>
          <select id="SortBy" class="bg-transparent border border-sbg-border/60 text-sbg-black p-1 text-[9px] uppercase tracking-wider focus:outline-none focus:border-sbg-black" onchange="location.href = this.value;">
            {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
            {%- for option in collection.sort_options -%}
              <option value="?sort_by={{ option.value }}" {% if option.value == sort_by %}selected="selected"{% endif %}>
                {{ option.name }}
              </option>
            {%- endfor -%}
          </select>
        </div>
      </div>

      <!-- Catalog Grid -->
      <div class="grid grid-cols-2 lg:grid-cols-{{ section.settings.columns | default: 3 }} gap-6 md:gap-8 reveal-on-scroll" data-stagger-children="0.08">
        {%- if collection.products.size > 0 -%}
          {%- for product in collection.products -%}
            {%- liquid
              assign current_variant = product.selected_or_first_available_variant
            -%}
            <a href="{{ product.url }}" class="col-card group block relative border border-sbg-border/50 hover:border-sbg-gold/30 hover:shadow-xl hover:shadow-sbg-gold/5 transition-all duration-500 stagger-item">
              <div class="relative overflow-hidden bg-sbg-offwhite {% if section.settings.aspect_ratio == 'square' %}aspect-square{% else %}aspect-[3/4]{% endif %}">
                <!-- Main image -->
                {%- if product.featured_image != blank -%}
                  <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}" class="col-card-img object-cover w-full h-full">
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'object-cover w-full h-full bg-sbg-hover' }}
                {%- endif -%}
                
                <!-- Hover image swap -->
                {%- if section.settings.show_second_image and product.images[1] != blank -%}
                  <img src="{{ product.images[1] | image_url: width: 800 }}" alt="{{ product.title }}" class="absolute inset-0 object-cover w-full h-full opacity-0 group-hover:opacity-100 transition-opacity duration-700">
                {%- endif -%}
                
                <!-- Availability / Sale badge -->
                {%- if current_variant.available == false -%}
                  <span class="absolute top-3 right-3 bg-sbg-black text-sbg-white text-[8px] font-bold tracking-widest uppercase px-2 py-1">
                    OUT OF STOCK
                  </span>
                {%- elsif product.compare_at_price > product.price -%}
                  <span class="absolute top-3 right-3 bg-sbg-gold text-sbg-white text-[8px] font-bold tracking-widest uppercase px-2 py-1">
                    SALE
                  </span>
                {%- endif -%}
              </div>
              
              <!-- Info -->
              <div class="p-4 bg-sbg-white border-t border-sbg-border/40 text-left space-y-1">
                <h3 class="text-[9px] tracking-[0.18em] uppercase text-sbg-grey/90 truncate font-semibold">
                  {{ product.vendor | default: "Styled by Gloria" }}
                </h3>
                <p class="font-display text-sm font-bold tracking-wide uppercase text-sbg-black truncate group-hover:text-sbg-gold transition-colors duration-300">
                  {{ product.title }}
                </p>
                <p class="text-xs font-semibold tracking-wider text-sbg-black/80">
                  {%- if product.price_varies -%}
                    From {{ product.price_min | money }}
                  {%- else -%}
                    {{ product.price | money }}
                  {%- endif -%}
                  {%- if product.compare_at_price > product.price -%}
                    <span class="text-sbg-grey line-through pl-1.5 font-normal text-[10px]">{{ product.compare_at_price | money }}</span>
                  {%- endif -%}
                </p>
              </div>
            </a>
          {%- endfor -%}
        {%- else -%}
          <!-- Empty/Fallback Catalog state -->
          {%- for i in (1..6) -%}
            <div class="col-card group block relative border border-sbg-border/50 hover:border-sbg-gold/30 hover:shadow-xl hover:shadow-sbg-gold/5 transition-all duration-500 stagger-item">
              <div class="relative overflow-hidden bg-sbg-offwhite {% if section.settings.aspect_ratio == 'square' %}aspect-square{% else %}aspect-[3/4]{% endif %}">
                {{ 'product-' | append: i | placeholder_svg_tag: 'object-cover w-full h-full bg-sbg-hover' }}
              </div>
              <div class="p-4 bg-sbg-white border-t border-sbg-border/40 text-left space-y-1">
                <h3 class="text-[9px] tracking-[0.18em] uppercase text-sbg-grey/90 font-semibold">STYLED BY GLORIA</h3>
                <p class="font-display text-sm font-bold tracking-wide uppercase text-sbg-black group-hover:text-sbg-gold transition-colors duration-300">
                  FALLBACK CATALOGUE PIECE {{ i }}
                </p>
                <p class="text-xs font-semibold tracking-wider text-sbg-black/80">$220.00 CAD</p>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <!-- Pagination Footer -->
      {%- if paginate.pages > 1 -%}
        <div class="flex items-center justify-center space-x-6 pt-12 border-t border-sbg-border/40 mt-12 text-[10px] tracking-widest text-sbg-grey uppercase font-semibold">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="hover:text-sbg-black flex items-center space-x-1">
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
              <span>PREVIOUS</span>
            </a>
          {%- endif -%}

          <span>PAGE {{ paginate.current_page }} OF {{ paginate.pages }}</span>

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="hover:text-sbg-black flex items-center space-x-1">
              <span>NEXT</span>
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    {%- endpaginate -%}

  </div>
</section>

{% schema %}
{
  "name": "SBG Collection Page",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 6,
      "max": 24,
      "step": 3,
      "label": "Products Per Page",
      "default": 12
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 3
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Card Aspect Ratio",
      "options": [
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (3:4)" }
      ],
      "default": "portrait"
    },
    {
      "type": "checkbox",
      "id": "show_second_image",
      "label": "Show Second Image on Hover",
      "default": true
    }
  ]
}
{% endschema %}
