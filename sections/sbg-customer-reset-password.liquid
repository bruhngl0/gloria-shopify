{%- comment -%}
  SBG Customer Reset Password — Password reset form
{%- endcomment -%}

<section class="bg-sbg-white w-full min-h-[calc(100vh-64px)] flex items-center justify-center py-16 md:py-24 select-none">
  <div class="w-full max-w-md mx-auto px-6">

    {%- comment -%} Header {%- endcomment -%}
    <div class="text-center mb-10">
      <span class="text-[9px] font-bold tracking-[0.3em] uppercase text-sbg-grey block mb-3">Account Security</span>
      <h1 class="font-display text-3xl md:text-4xl font-bold tracking-[0.15em] uppercase text-sbg-black">
        Reset Password
      </h1>
      <div class="h-[1px] w-12 bg-sbg-black mx-auto mt-4 mb-4"></div>
      <p class="text-[10px] tracking-wider text-sbg-grey leading-relaxed">
        Enter your new password below.
      </p>
    </div>

    {%- comment -%} Reset Form {%- endcomment -%}
    {%- form 'reset_customer_password' -%}
      <div class="space-y-5">
        {%- if form.errors -%}
          <div class="border border-red-300 bg-red-50 p-4 text-[10px] tracking-wider uppercase text-red-700">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="space-y-1.5">
          <label for="ResetPassword" class="text-[9px] font-bold tracking-[0.2em] uppercase text-sbg-black block">
            New Password
          </label>
          <input
            type="password"
            name="customer[password]"
            id="ResetPassword"
            autocomplete="new-password"
            required
            class="w-full border border-sbg-border bg-sbg-white px-4 py-3 text-xs tracking-wider text-sbg-black placeholder:text-sbg-grey/60 focus:outline-none focus:border-sbg-black transition-colors"
            placeholder="Minimum 5 characters"
          >
        </div>

        <div class="space-y-1.5">
          <label for="ResetPasswordConfirm" class="text-[9px] font-bold tracking-[0.2em] uppercase text-sbg-black block">
            Confirm Password
          </label>
          <input
            type="password"
            name="customer[password_confirmation]"
            id="ResetPasswordConfirm"
            autocomplete="new-password"
            required
            class="w-full border border-sbg-border bg-sbg-white px-4 py-3 text-xs tracking-wider text-sbg-black placeholder:text-sbg-grey/60 focus:outline-none focus:border-sbg-black transition-colors"
            placeholder="Re-enter password"
          >
        </div>

        <button
          type="submit"
          class="w-full py-3.5 text-[10px] font-bold uppercase tracking-[0.25em] bg-sbg-black text-sbg-white hover:opacity-90 active:scale-[0.98] transition-all"
        >
          Reset Password
        </button>
      </div>
    {%- endform -%}

  </div>
</section>

{% schema %}
{
  "name": "Customer Reset Password",
  "settings": []
}
{% endschema %}
