{%- comment -%}
  SBG Editorial Contact Section
  Translates the Next.js contact page layout into a native Shopify contact form.
{%- endcomment -%}

<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-24 md:pt-32 pb-12 md:pb-24 select-none">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
    
    <!-- LEFT COLUMN: Contact Information -->
    <div class="lg:col-span-5 space-y-8 reveal-on-scroll" data-stagger-children="0.12">
      <div class="space-y-4 stagger-item">
        <span class="text-[10px] font-bold tracking-[0.3em] uppercase text-sbg-grey block">
          {{ section.settings.sub_label | default: "Get In Touch" }}
        </span>
        <h1 class="font-display text-3xl md:text-5xl font-bold tracking-[0.2em] text-sbg-black uppercase leading-tight">
          {{ section.settings.title | default: "Contact Us" }}
        </h1>
        <div class="h-[1px] w-16 bg-sbg-black mt-4 mb-6"></div>
        <p class="text-xs tracking-wider leading-relaxed text-sbg-grey max-w-md">
          {{ section.settings.description | default: "Have a question about sizing, your order, or interested in a custom styling transformation package? Send us a message, and our styling office will assist you." }}
        </p>
      </div>

      <div class="space-y-6 pt-6 border-t border-sbg-border/60 stagger-item">
        <!-- Email Card -->
        <div class="flex items-start space-x-4">
          <div class="p-3 bg-sbg-offwhite border border-sbg-border/60 rounded-full flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-4.5 w-4.5 text-sbg-black"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <div class="space-y-1 text-left">
            <h3 class="text-[10px] font-bold tracking-widest uppercase text-sbg-black">
              Email Us
            </h3>
            <a
              href="mailto:{{ section.settings.email | default: 'styling@styledbygloria.com' }}"
              class="text-xs tracking-wider text-sbg-grey hover:text-sbg-black transition-colors"
            >
              {{ section.settings.email | default: 'styling@styledbygloria.com' }}
            </a>
          </div>
        </div>

        <!-- Social Card -->
        <div class="flex items-start space-x-4">
          <div class="p-3 bg-sbg-offwhite border border-sbg-border/60 rounded-full flex items-center justify-center">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-4.5 w-4.5 text-sbg-black">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
            </svg>
          </div>
          <div class="space-y-1 text-left">
            <h3 class="text-[10px] font-bold tracking-widest uppercase text-sbg-black">
              Direct Message
            </h3>
            <a
              href="{{ section.settings.social_link | default: 'https://instagram.com/styledbygloria_g' }}"
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs tracking-wider text-sbg-grey hover:text-sbg-black transition-colors"
            >
              {{ section.settings.social_handle | default: '@styledbygloria_g' }}
            </a>
          </div>
        </div>
      </div>

      <!-- SLA note -->
      <div class="bg-sbg-offwhite p-6 border border-sbg-border/50 text-[11px] tracking-wider text-sbg-grey leading-relaxed text-left stagger-item">
        {{ section.settings.sla_note | default: "Please allow up to 48 hours for our team to review your details and respond. For size-specific inquiries, sharing your bust, waist, and hip measurements is highly encouraged!" }}
      </div>
    </div>

    <!-- RIGHT COLUMN: Interactive Form -->
    <div class="lg:col-span-7 bg-sbg-white border border-sbg-border p-8 md:p-10 reveal-on-scroll">
      {%- form 'contact', id: 'ContactForm' -%}
        
        <!-- Success State -->
        {%- if form.posted_successfully? -%}
          <div class="flex flex-col items-center justify-center py-12 text-center space-y-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="green" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-12 w-12"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
            <h3 class="font-display text-xl font-bold tracking-wider text-sbg-black uppercase">
              Message Sent
            </h3>
            <p class="text-xs tracking-wider text-sbg-grey max-w-sm leading-relaxed">
              Thank you for reaching out to Styled by Gloria. Your inquiry has been received, and our styling lead will follow up shortly.
            </p>
            <a
              href="{{ request.path }}"
              class="text-xs font-bold tracking-widest text-sbg-black uppercase border-b border-sbg-black hover:opacity-80 pb-0.5 pt-4"
            >
              Send Another Message
            </a>
          </div>
        {%- else -%}
          
          <div class="space-y-6 text-left">
            <!-- Form Errors -->
            {%- if form.errors -%}
              <div class="p-4 bg-red-50 border border-red-200 text-red-800 text-xs tracking-wider flex items-start space-x-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="h-4.5 w-4.5 shrink-0"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>
                <span>{{ form.errors | default_errors }}</span>
              </div>
            {%- endif -%}

            <!-- Name Input -->
            <div class="space-y-2">
              <label for="ContactForm-Name" class="text-[10px] font-bold uppercase tracking-widest text-sbg-black block">
                Your Name <span class="text-red-700">*</span>
              </label>
              <input
                type="text"
                id="ContactForm-Name"
                name="contact[name]"
                value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                required
                class="w-full px-4 py-3 border border-sbg-border text-xs tracking-wider transition-colors focus:outline-none focus:border-sbg-black"
                placeholder="E.g., Jane Smith"
              >
            </div>

            <!-- Email Input -->
            <div class="space-y-2">
              <label for="ContactForm-Email" class="text-[10px] font-bold uppercase tracking-widest text-sbg-black block">
                Email Address <span class="text-red-700">*</span>
              </label>
              <input
                type="email"
                id="ContactForm-Email"
                name="contact[email]"
                value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                required
                class="w-full px-4 py-3 border border-sbg-border text-xs tracking-wider transition-colors focus:outline-none focus:border-sbg-black"
                placeholder="E.g., jane@example.com"
              >
            </div>

            <!-- Custom Subject Input -->
            <div class="space-y-2">
              <label for="ContactForm-Subject" class="text-[10px] font-bold uppercase tracking-widest text-sbg-black block">
                Subject <span class="text-red-700">*</span>
              </label>
              <select
                id="ContactForm-Subject"
                name="contact[subject]"
                class="w-full px-4 py-3 border border-sbg-border bg-sbg-white text-xs tracking-wider transition-colors focus:outline-none focus:border-sbg-black"
              >
                <option value="General Inquiry">General Inquiry</option>
                <option value="Styling Services">Styling Services Inquiry</option>
                <option value="Order Question">Order Question</option>
                <option value="Press">Press Inquiry</option>
              </select>
            </div>

            <!-- Message Textarea -->
            <div class="space-y-2">
              <label for="ContactForm-Message" class="text-[10px] font-bold uppercase tracking-widest text-sbg-black block">
                Message <span class="text-red-700">*</span>
              </label>
              <textarea
                rows="6"
                id="ContactForm-Message"
                name="contact[body]"
                required
                class="w-full px-4 py-3 border border-sbg-border text-xs tracking-wider transition-colors focus:outline-none focus:border-sbg-black resize-y"
                placeholder="Write your message here... Include your measurements if looking for fit advice."
              >{% if form.body %}{{ form.body }}{% endif %}</textarea>
            </div>

            <!-- Submit Button -->
            <div class="pt-2">
              <button
                type="submit"
                class="w-full py-4 text-xs font-bold uppercase tracking-widest border border-sbg-black bg-sbg-black text-sbg-white hover:bg-sbg-white hover:text-sbg-black transition-colors focus:outline-none"
              >
                Send Message
              </button>
            </div>
          </div>

        {%- endif -%}

      {%- endform -%}
    </div>

  </div>
</div>

<script>
  // Handle URL query parameters for pre-filling inquiries from services page
  document.addEventListener('DOMContentLoaded', function() {
    const params = new URLSearchParams(window.location.search);
    const subjectParam = params.get('subject');
    const serviceParam = params.get('service');

    if (subjectParam) {
      const subjectSelect = document.getElementById('ContactForm-Subject');
      if (subjectSelect) {
        subjectSelect.value = subjectParam;
      }
    }

    if (serviceParam) {
      const messageTextarea = document.getElementById('ContactForm-Message');
      if (messageTextarea) {
        messageTextarea.value = 'Hello Gloria,\n\nI am writing to enquire about the "' + serviceParam + '" program. Please provide more details regarding booking availability and custom styling timelines.\n\nThank you!';
      }
    }
  });
</script>

{% schema %}
{
  "name": "SBG Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "sub_label",
      "label": "Sub-label Text",
      "default": "Get In Touch"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Header Title",
      "default": "Contact Us"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Have a question about sizing, your order, or interested in a custom styling transformation package? Send us a message, and our styling office will assist you."
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email Address",
      "default": "styling@styledbygloria.com"
    },
    {
      "type": "text",
      "id": "social_handle",
      "label": "Instagram Handle",
      "default": "@styledbygloria_g"
    },
    {
      "type": "url",
      "id": "social_link",
      "label": "Instagram Link"
    },
    {
      "type": "textarea",
      "id": "sla_note",
      "label": "SLA Notice",
      "default": "Please allow up to 48 hours for our team to review your details and respond. For size-specific inquiries, sharing your bust, waist, and hip measurements is highly encouraged!"
    }
  ],
  "presets": [
    {
      "name": "SBG Contact Form"
    }
  ]
}
{% endschema %}
