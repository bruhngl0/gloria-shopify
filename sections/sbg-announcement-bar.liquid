{%- comment -%}
  SBG Sticky top announcement bar for announcements and promotions
{%- endcomment -%}

{%- if section.settings.show_announcement -%}
  <style type="text/css">
    #SBG-AnnouncementBar {
      background-color: {{ section.settings.bg_color }};
      color: {{ section.settings.text_color }};
      font-size: {{ section.settings.font_size }}px;
      letter-spacing: 0.25em;
      transition: transform 0.35s ease;
    }
    .announcement-bar-close {
      color: inherit;
      opacity: 0.7;
      transition: opacity 0.2s ease;
    }
    .announcement-bar-close:hover {
      opacity: 1;
    }
  </style>

  <div id="SBG-AnnouncementBar" class="relative w-full z-50 flex items-center justify-between px-6 py-2.5 font-body uppercase select-none text-center">
    <div class="flex-1 flex justify-center items-center">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="hover:underline transition duration-300">
          {{ section.settings.text }}
        </a>
      {%- else -%}
        <span>{{ section.settings.text }}</span>
      {%- endif -%}
    </div>

    {%- if section.settings.show_close_button -%}
      <button onclick="closeAnnouncementBar()" class="announcement-bar-close p-1 focus:outline-none cursor-pointer absolute right-4 top-1/2 -translate-y-1/2" aria-label="Close announcement">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    {%- endif -%}
  </div>

  <script>
    function closeAnnouncementBar() {
      const bar = document.getElementById('SBG-AnnouncementBar');
      if (bar) {
        bar.style.display = 'none';
        // Adjust fixed header offset if needed
        const header = document.getElementById('SBG-Header');
        if (header) {
          header.style.top = '0';
        }
      }
    }

    // Dynamic sticky header adjustment when announcement bar is loaded
    document.addEventListener('DOMContentLoaded', function() {
      const bar = document.getElementById('SBG-AnnouncementBar');
      const header = document.getElementById('SBG-Header');
      if (bar && header && {{ section.settings.sticky | json }}) {
        header.style.top = bar.offsetHeight + 'px';
      }
    });
  </script>
{%- endif -%}

{% schema %}
{
  "name": "SBG Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show Announcement Bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "sticky",
      "label": "Sticky Top Position",
      "default": false
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "Free shipping on international orders over $250"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link Url"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0A0A0A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 8,
      "max": 12,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 9
    },
    {
      "type": "checkbox",
      "id": "show_close_button",
      "label": "Show Close Button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "SBG Announcement Bar"
    }
  ]
}
{% endschema %}
