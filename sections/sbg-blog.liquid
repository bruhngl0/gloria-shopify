{%- comment -%}
  SBG Editorial Blog Listing Template
  Displays blog listing index with grid layouts and excerpts.
{%- endcomment -%}

<style type="text/css">
  .blog-card-img {
    transition: transform 0.9s cubic-bezier(0.215, 0.61, 0.355, 1);
  }
  .blog-card:hover .blog-card-img {
    transform: scale(1.03);
  }
</style>

<section class="bg-sbg-white w-full py-16 md:py-24 border-b border-sbg-border/60 select-none">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 reveal-on-scroll" data-stagger-children="0.1">
      <span class="text-[10px] font-bold tracking-[0.3em] uppercase text-sbg-grey block mb-2 stagger-item">
        Atelier Journal
      </span>
      <h1 class="font-display text-4xl md:text-5xl font-bold tracking-[0.2em] text-sbg-black uppercase stagger-item">
        {{ blog.title }}
      </h1>
      <div class="h-[1px] w-16 bg-sbg-black mx-auto mt-4 mb-6 stagger-item"></div>
    </div>

    {%- liquid
      assign articles_per_page = section.settings.articles_per_page | default: 6
    -%}

    {%- paginate blog.articles by articles_per_page -%}
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 reveal-on-scroll" data-stagger-children="0.1">
        {%- if blog.articles.size > 0 -%}
          {%- for article in blog.articles -%}
            <article class="blog-card group flex flex-col space-y-4 border border-sbg-border/50 bg-sbg-offwhite p-5 hover:border-sbg-gold/30 hover:shadow-xl hover:shadow-sbg-gold/5 transition-all duration-500 stagger-item">
              
              <!-- Featured Image -->
              <a href="{{ article.url }}" class="block overflow-hidden relative aspect-video bg-sbg-white border border-sbg-border/40">
                {%- if article.image != blank -%}
                  <img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.title }}" class="blog-card-img object-cover w-full h-full">
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'object-cover w-full h-full bg-sbg-hover opacity-85' }}
                {%- endif -%}
              </a>

              <!-- Info -->
              <div class="flex-1 flex flex-col justify-between space-y-3 pt-2 text-left">
                <div class="space-y-2">
                  <div class="flex items-center space-x-2 text-[8px] font-bold tracking-[0.25em] text-sbg-grey uppercase">
                    <span>{{ article.published_at | date: "%B %d, %Y" }}</span>
                    <span>•</span>
                    <span>BY {{ article.author | default: "GLORIA" }}</span>
                  </div>

                  <h3 class="font-display text-lg font-bold tracking-wide uppercase text-sbg-black group-hover:text-sbg-gold transition-colors duration-300">
                    <a href="{{ article.url }}">{{ article.title }}</a>
                  </h3>

                  {%- if article.excerpt != blank or article.content != blank -%}
                    <p class="text-[11px] tracking-wider leading-relaxed text-sbg-grey/90 line-clamp-3">
                      {{ article.excerpt | default: article.content | strip_html | truncate: 150 }}
                    </p>
                  {%- endif -%}
                </div>

                <div class="pt-2">
                  <a href="{{ article.url }}" class="inline-flex items-center space-x-1.5 text-[9px] font-bold tracking-[0.25em] text-sbg-black hover:text-sbg-gold uppercase transition-colors duration-300">
                    <span>READ POST</span>
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  </a>
                </div>
              </div>

            </article>
          {%- endfor -%}
        {%- else -%}
          <!-- Fallback Editorial Posts -->
          {%- for i in (1..3) -%}
            <article class="blog-card group flex flex-col space-y-4 border border-sbg-border/50 bg-sbg-offwhite p-5 hover:border-sbg-gold/30 hover:shadow-xl hover:shadow-sbg-gold/5 transition-all duration-500 stagger-item">
              <div class="block overflow-hidden relative aspect-video bg-sbg-white border border-sbg-border/40">
                {{ 'lifestyle-' | append: i | placeholder_svg_tag: 'object-cover w-full h-full bg-sbg-hover' }}
              </div>
              <div class="flex-1 flex flex-col justify-between space-y-3 pt-2 text-left">
                <div class="space-y-2">
                  <div class="flex items-center space-x-2 text-[8px] font-bold tracking-[0.25em] text-sbg-grey uppercase">
                    <span>JUNE 15, 2026</span>
                    <span>•</span>
                    <span>BY GLORIA EDITOR</span>
                  </div>
                  <h3 class="font-display text-lg font-bold tracking-wide uppercase text-sbg-black">
                    FALLBACK EDITORIAL ARTICLE {{ i }}
                  </h3>
                  <p class="text-[11px] tracking-wider leading-relaxed text-sbg-grey/90">
                    A conceptual overview detailing draping techniques, color palette guidelines, and fabric mechanics for standard silhouette structures.
                  </p>
                </div>
                <div class="pt-2">
                  <span class="inline-flex items-center space-x-1.5 text-[9px] font-bold tracking-[0.25em] text-sbg-black uppercase">
                    <span>READ POST</span>
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </article>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <!-- Pagination -->
      {%- if paginate.pages > 1 -%}
        <div class="flex items-center justify-center space-x-6 pt-12 border-t border-sbg-border/40 mt-12 text-[10px] tracking-widest text-sbg-grey uppercase font-semibold">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="hover:text-sbg-black flex items-center space-x-1">
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
              <span>PREVIOUS</span>
            </a>
          {%- endif -%}

          <span>PAGE {{ paginate.current_page }} OF {{ paginate.pages }}</span>

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="hover:text-sbg-black flex items-center space-x-1">
              <span>NEXT</span>
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    {%- endpaginate -%}

  </div>
</section>

{% schema %}
{
  "name": "SBG Blog Index",
  "settings": [
    {
      "type": "range",
      "id": "articles_per_page",
      "min": 3,
      "max": 12,
      "step": 3,
      "label": "Articles Per Page",
      "default": 6
    }
  ]
}
{% endschema %}
