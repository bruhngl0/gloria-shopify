{%- comment -%}
  SBG Customer Account — Editorial account dashboard with order history
{%- endcomment -%}

<section class="bg-sbg-white w-full py-16 md:py-24 select-none">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">

    {%- comment -%} Header {%- endcomment -%}
    <div class="text-center mb-12">
      <span class="text-[9px] font-bold tracking-[0.3em] uppercase text-sbg-grey block mb-3">Client Portal</span>
      <h1 class="font-display text-3xl md:text-4xl font-bold tracking-[0.15em] uppercase text-sbg-black">
        Welcome, {{ customer.first_name }}
      </h1>
      <div class="h-[1px] w-12 bg-sbg-black mx-auto mt-4 mb-4"></div>
      <a href="{{ routes.account_logout_url }}" class="text-[9px] tracking-[0.2em] uppercase text-sbg-grey hover:text-sbg-black underline underline-offset-4 transition-colors">
        Sign Out
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">

      {%- comment -%} Order History {%- endcomment -%}
      <div class="md:col-span-8">
        <div class="flex items-center justify-between border-b border-sbg-border pb-4 mb-6">
          <h2 class="text-[10px] font-bold tracking-[0.25em] uppercase text-sbg-black">
            Order History
          </h2>
          <span class="text-[9px] tracking-widest text-sbg-grey uppercase">
            {{ customer.orders_count }} {{ customer.orders_count | pluralize: 'Order', 'Orders' }}
          </span>
        </div>

        {%- if customer.orders.size > 0 -%}
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="border-b border-sbg-border">
                  <th class="py-3 text-[9px] font-bold tracking-[0.2em] uppercase text-sbg-black">Order</th>
                  <th class="py-3 text-[9px] font-bold tracking-[0.2em] uppercase text-sbg-black">Date</th>
                  <th class="py-3 text-[9px] font-bold tracking-[0.2em] uppercase text-sbg-black">Status</th>
                  <th class="py-3 text-[9px] font-bold tracking-[0.2em] uppercase text-sbg-black text-right">Total</th>
                </tr>
              </thead>
              <tbody>
                {%- for order in customer.orders -%}
                  <tr class="border-b border-sbg-border/40 hover:bg-sbg-offwhite transition-colors">
                    <td class="py-4">
                      <a href="{{ order.customer_url }}" class="text-xs font-semibold tracking-wider text-sbg-black hover:underline underline-offset-4">
                        {{ order.name }}
                      </a>
                    </td>
                    <td class="py-4 text-[10px] tracking-wider text-sbg-grey">
                      {{ order.created_at | date: '%B %d, %Y' }}
                    </td>
                    <td class="py-4">
                      <span class="inline-block px-2.5 py-1 text-[8px] font-bold tracking-widest uppercase
                        {%- if order.fulfillment_status == 'fulfilled' %} bg-green-50 text-green-700 border border-green-200
                        {%- elsif order.fulfillment_status == 'partial' %} bg-yellow-50 text-yellow-700 border border-yellow-200
                        {%- else %} bg-sbg-offwhite text-sbg-grey border border-sbg-border
                        {%- endif -%}
                      ">
                        {{ order.fulfillment_status_label }}
                      </span>
                    </td>
                    <td class="py-4 text-xs font-semibold tracking-wider text-sbg-black text-right">
                      {{ order.total_price | money }}
                    </td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>
          </div>

          {%- comment -%} Pagination {%- endcomment -%}
          {%- paginate customer.orders by 10 -%}
            {%- if paginate.pages > 1 -%}
              <div class="flex items-center justify-center space-x-6 pt-8 text-[10px] tracking-widest text-sbg-grey uppercase font-semibold">
                {%- if paginate.previous -%}
                  <a href="{{ paginate.previous.url }}" class="hover:text-sbg-black transition-colors">
                    &larr; Previous
                  </a>
                {%- endif -%}
                <span>Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
                {%- if paginate.next -%}
                  <a href="{{ paginate.next.url }}" class="hover:text-sbg-black transition-colors">
                    Next &rarr;
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endpaginate -%}

        {%- else -%}
          <div class="text-center py-16 border border-sbg-border/40">
            <p class="text-[10px] tracking-wider text-sbg-grey uppercase mb-4">
              No orders yet
            </p>
            <a
              href="{{ routes.all_products_collection_url }}"
              class="inline-block px-8 py-3 text-[10px] font-bold uppercase tracking-[0.25em] bg-sbg-black text-sbg-white hover:opacity-90 transition-all"
            >
              Start Shopping
            </a>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Account Sidebar {%- endcomment -%}
      <div class="md:col-span-4">
        <div class="border border-sbg-border/60 p-6 space-y-6">
          <div>
            <h3 class="text-[10px] font-bold tracking-[0.25em] uppercase text-sbg-black mb-4 pb-3 border-b border-sbg-border/60">
              Account Details
            </h3>
            <div class="space-y-3 text-[10px] tracking-wider text-sbg-grey leading-relaxed">
              <p class="font-semibold text-sbg-black">{{ customer.name }}</p>
              <p>{{ customer.email }}</p>
              {%- if customer.default_address -%}
                <div class="pt-3 border-t border-sbg-border/40">
                  <p>{{ customer.default_address.address1 }}</p>
                  {%- if customer.default_address.address2 != blank -%}
                    <p>{{ customer.default_address.address2 }}</p>
                  {%- endif -%}
                  <p>{{ customer.default_address.city }}, {{ customer.default_address.province_code }} {{ customer.default_address.zip }}</p>
                  <p>{{ customer.default_address.country }}</p>
                </div>
              {%- endif -%}
            </div>
          </div>

          <a
            href="{{ routes.account_addresses_url }}"
            class="block w-full py-3 text-center text-[10px] font-bold uppercase tracking-[0.25em] border border-sbg-black text-sbg-black hover:bg-sbg-black hover:text-sbg-white transition-all"
          >
            Manage Addresses
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Customer Account",
  "settings": []
}
{% endschema %}
