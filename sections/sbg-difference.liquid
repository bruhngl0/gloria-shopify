{%- comment -%}
  SBG Editorial Difference layout with stacked visual graphics ("Symmetric / SHAPE") and details paragraph
{%- endcomment -%}

<section class="bg-sbg-white w-full py-20 md:py-28 border-b border-sbg-border overflow-hidden select-none">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Top Section Tag -->
    <div class="text-center mb-10 md:mb-12">
      <span class="text-[9px] tracking-[0.25em] font-bold text-sbg-grey uppercase">
        {{ section.settings.section_tag | default: 'THE SBG DIFFERENCE' }}
      </span>
    </div>

    <!-- 1. LAYERED EDITORIAL ARTWORK BLOCK -->
    <div class="relative flex flex-col justify-center items-center w-full min-h-[300px] md:min-h-[440px] mb-16 select-none reveal-on-scroll">
      <!-- Layer 1: Back Text (Cursive script) -->
      <h3 class="font-cursive text-[80px] md:text-[9.5rem] text-sbg-black leading-none absolute z-0 select-none -translate-y-24 md:-translate-y-40 font-normal">
        {{ section.settings.back_text | default: 'Symmetric' }}
      </h3>

      <!-- Layer 2: Center Image Card -->
      <div class="w-[180px] h-[240px] md:w-[240px] md:h-[320px] relative z-10 bg-sbg-offwhite border border-sbg-border/60 shadow-sm overflow-hidden select-none">
        {%- if section.settings.center_image != blank -%}
          <img src="{{ section.settings.center_image | image_url: width: 600 }}" alt="{{ section.settings.center_image.alt | default: 'Atelier cowl detail' }}" class="w-full h-full object-cover">
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'w-full h-full object-cover opacity-70 bg-sbg-hover' }}
        {%- endif -%}
      </div>

      <!-- Layer 3: Front Text (Bold/Light sans-serif) -->
      <h3 class="font-sans font-light text-[55px] md:text-[7.8rem] tracking-[0.05em] text-sbg-black leading-none absolute z-20 select-none translate-y-8 md:translate-y-12 uppercase">
        {{ section.settings.front_text | default: 'SHAPE' }}
      </h3>
    </div>

    <!-- Tagline below graphic -->
    <div class="text-center mb-16 md:mb-24">
      <p class="text-[10px] tracking-[0.2em] uppercase text-sbg-black font-semibold">
        {{ section.settings.tagline_left | default: 'ECHOES OF —' }} <span class="italic font-display font-normal">{{ section.settings.tagline_right | default: 'SILHOUETTE HARMONY' }}</span>
      </p>
    </div>

    <!-- 2. SINGLE EDITORIAL PARAGRAPH -->
    <div class="max-w-2xl mx-auto text-center border-t border-sbg-border/60 pt-16 px-4 reveal-on-scroll">
      <p class="text-[11px] md:text-[12px] tracking-wider text-sbg-grey leading-relaxed">
        {{ section.settings.paragraph | default: 'Every piece is designed around how it serves specific shapes, offering customizable elements to contour to your proportions rather than standard grids. We are not here to move inventory—our primary objective is to empower you to look and feel authentic in your own skin and capsule designs. This is collaborative personal styling that treats you as the expert on your own body, teaching you styling rules that last a lifetime.' }}
      </p>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "SBG Editorial Difference",
  "settings": [
    {
      "type": "text",
      "id": "section_tag",
      "label": "Section Tag",
      "default": "THE SBG DIFFERENCE"
    },
    {
      "type": "text",
      "id": "back_text",
      "label": "Back Script Text (Cursive)",
      "default": "Symmetric"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center Overlay Image"
    },
    {
      "type": "text",
      "id": "front_text",
      "label": "Front Title Text (Sans-serif)",
      "default": "SHAPE"
    },
    {
      "type": "text",
      "id": "tagline_left",
      "label": "Tagline Left Part",
      "default": "ECHOES OF —"
    },
    {
      "type": "text",
      "id": "tagline_right",
      "label": "Tagline Right Part (Italic)",
      "default": "SILHOUETTE HARMONY"
    },
    {
      "type": "textarea",
      "id": "paragraph",
      "label": "Details Paragraph Text",
      "default": "Every piece is designed around how it serves specific shapes, offering customizable elements to contour to your proportions rather than standard grids. We are not here to move inventory—our primary objective is to empower you to look and feel authentic in your own skin and capsule designs. This is collaborative personal styling that treats you as the expert on your own body, teaching you styling rules that last a lifetime."
    }
  ],
  "presets": [
    {
      "name": "SBG Editorial Difference"
    }
  ]
}
{% endschema %}
