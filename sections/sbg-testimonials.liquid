{%- comment -%}
  SBG Client Testimonials & Social Proof Grid/Slider section
{%- endcomment -%}

<style type="text/css">
  .testimonial-card {
    transition: transform 0.4s cubic-bezier(0.215, 0.61, 0.355, 1), border-color 0.3s ease;
  }
  .testimonial-card:hover {
    transform: translateY(-6px);
    border-color: rgba(197, 168, 128, 0.3);
    box-shadow: 0 20px 25px -5px rgba(197, 168, 128, 0.05);
  }
</style>

<div class="bg-sbg-offwhite w-full py-20 border-b border-sbg-border/60 select-none">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 reveal-on-scroll" data-stagger-children="0.1">
      <span class="text-[10px] font-bold tracking-[0.3em] uppercase text-sbg-gold block mb-2 stagger-item">
        {{ section.settings.sub_label | default: "Social Proof" }}
      </span>
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-[0.2em] text-sbg-black uppercase stagger-item">
        {{ section.settings.title | default: "Atelier Testimonials" }}
      </h2>
      <div class="h-[1px] w-16 bg-sbg-gold mx-auto mt-4 stagger-item"></div>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-{{ section.settings.columns | default: 3 }} gap-8 reveal-on-scroll" data-stagger-children="0.12">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="testimonial-card p-8 md:p-10 border border-sbg-border bg-sbg-white flex flex-col justify-between space-y-6 text-left stagger-item" {{ block.shopify_attributes }}>
            <div class="space-y-4">
              <!-- Rating stars -->
              {%- if block.settings.rating > 0 -%}
                <div class="flex space-x-1 text-sbg-gold">
                  {%- for star in (1..block.settings.rating) -%}
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="h-3.5 w-3.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  {%- endfor -%}
                </div>
              {%- endif -%}

              <!-- Quote -->
              <p class="font-display text-base md:text-lg italic tracking-wide text-sbg-black leading-relaxed">
                "{{ block.settings.quote }}"
              </p>
            </div>

            <!-- Author info -->
            <div class="pt-4 border-t border-sbg-border/60">
              <span class="text-[10px] font-bold tracking-widest text-sbg-black uppercase block">
                {{ block.settings.author }}
              </span>
              <span class="text-[8px] tracking-[0.2em] text-sbg-grey uppercase block mt-1 font-semibold">
                {{ block.settings.silhouette }}
              </span>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- Fallback Cards -->
        <div class="testimonial-card p-8 md:p-10 border border-sbg-border bg-sbg-white flex flex-col justify-between space-y-6 text-left stagger-item">
          <div class="space-y-4">
            <div class="flex space-x-1 text-sbg-gold">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="h-3.5 w-3.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="h-3.5 w-3.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="h-3.5 w-3.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="h-3.5 w-3.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="h-3.5 w-3.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            </div>
            <p class="font-display text-base md:text-lg italic tracking-wide text-sbg-black leading-relaxed">
              "The fit-adjustability of the One For All dress completely redefined how I view sizing. The crepe holds memory perfectly."
            </p>
          </div>
          <div class="pt-4 border-t border-sbg-border/60">
            <span class="text-[10px] font-bold tracking-widest text-sbg-black uppercase block">Sarah H.</span>
            <span class="text-[8px] tracking-[0.2em] text-sbg-grey uppercase block mt-1 font-semibold">Pear Shape Profile</span>
          </div>
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "SBG Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "sub_label",
      "label": "Sub-label",
      "default": "Social Proof"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Main Title",
      "default": "Atelier Testimonials"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial Card",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star Rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote Text",
          "default": "Review text..."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Client Name"
        },
        {
          "type": "text",
          "id": "silhouette",
          "label": "Client Profile (e.g. Shape Profile)",
          "default": "Shape Profile"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SBG Testimonials"
    }
  ]
}
{% endschema %}
