{%- comment -%}
  SBG Editorial Static Page Template rendering
{%- endcomment -%}

<section class="bg-sbg-white w-full py-16 md:py-28 select-none">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <h1 class="font-display text-3xl md:text-5xl font-bold tracking-[0.15em] text-sbg-black uppercase text-center mb-8">
      {{ page.title }}
    </h1>
    <div class="h-[1px] w-16 bg-sbg-black mx-auto mb-12"></div>
    <div class="prose prose-sbg text-xs tracking-wider leading-relaxed text-sbg-grey uppercase-none">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page Content",
  "settings": []
}
{% endschema %}
